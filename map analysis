#!/usr/bin/env python3
import numpy as np
import matplotlib.pyplot as plt
from PIL import Image
import os


def load_and_display_maps():
    maps = {
        'LiDAR SLAM': '/home/matth/maps/lidar_slam_map.pgm',
        'Hybrid SLAM': '/home/matth/maps/hybrid_slam_final.pgm',
    }

    fig, axes = plt.subplots(1, 2, figsize=(14, 6))
    fig.suptitle('Map Quality Comparison', fontsize=14, fontweight='bold')

    for idx, (title, path) in enumerate(maps.items()):
        if os.path.exists(path):
            img = Image.open(path)
            arr = np.array(img)
            axes[idx].imshow(arr, cmap='gray')
            axes[idx].set_title(title)
            axes[idx].set_xlabel('X (pixels)')
            axes[idx].set_ylabel('Y (pixels)')

            occupied = np.sum(arr < 50)
            free = np.sum(arr > 200)
            total = arr.size
            coverage = (occupied + free) / total * 100
            print(f'{title}: {coverage:.1f}% coverage, '
                  f'{occupied} wall pixels, {free} free pixels')

    plt.tight_layout()
    plt.savefig('/home/matth/maps/comparison_final.png',
                dpi=150, bbox_inches='tight')
    plt.show()


if __name__ == '__main__':
    load_and_display_maps()
